# stage 1 - builder
FROM python:3.12 AS builder
WORKDIR /docker-project
COPY requirements.txt .
# Build wheels into a wheelhouse folder
RUN pip wheel --no-cache-dir --no-deps --wheel-dir /docker-project/wheels -r requirements.txt

# stage 2 - runtime
FROM python:3.12-slim
WORKDIR /docker-project

# Copy wheels from builder and install them locally
COPY --from=builder /docker-project/wheels /wheels
COPY --from=builder /docker-project/requirements.txt .
RUN pip install --no-cache /wheels/*

# Install curl for healthcheck
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Copy app code
COPY . .

CMD ["python", "script.py"]
